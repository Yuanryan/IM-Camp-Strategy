// IM 大富翁：迷霧資本戰 — 策略系統 資料模型
// 用 SQLite 開發；正式可改 provider 為 postgresql。
// JSON 一律以 String 欄位存放（JSON.parse/stringify），避免 provider 差異。

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // 單一連線：用 Supabase「Session pooler」(5432, IPv4)，app 與 db push 都走它
  url      = env("DATABASE_URL")
  // 時區設定：所有 Timestamptz 欄位以 Asia/Taipei（GMT+8）讀寫
  // Supabase 可在 Dashboard → Database → Extensions or SQL: SET timezone = 'Asia/Taipei'
}

// 本機若想改用 SQLite 開發，把上面整段換成：
// datasource db { provider = "sqlite"  url = env("DATABASE_URL") }
// 並把 .env 的 DATABASE_URL 設為 "file:./dev.db"

// 登入用：每個站別 / 小隊一條不可猜 token
model AccessToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  role      String // HOST EXCHANGE MAP MOBILE CARDSHOP LOTTERY PROJECTION ADMIN TEAM
  label     String // 顯示用：例如「交易所-1」「第3隊」
  teamId    Int?
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now()) @db.Timestamptz
}

model Team {
  id             Int             @id @default(autoincrement())
  name           String
  coins          Int             @default(0) // 光幣
  cardPoints     Int             @default(0) // 卡牌點數
  boardPos       Int             @default(0) // 棋子目前格 index（0=中央燈塔起點；見 lib/game.ts BOARD）
  properties     Property[]
  lotteryNumbers LotteryNumber[]
  ledgers        Ledger[]
  tokens         AccessToken[]
  items          TeamItem[]
  auctionsWon    AuctionLot[]
  objectives     TeamObjective[]
  cards          TeamCard[]
  createdAt      DateTime        @default(now()) @db.Timestamptz
}

// 拍賣場次：一個事件包含多件拍賣品，並承載對小隊的公告橫幅。
// 建立即顯示公告橫幅（不需主持人額外操作），ENDED 後不再顯示。
model AuctionEvent {
  id           Int          @id @default(autoincrement())
  name         String // 場次名稱，例如「期中大拍賣」
  announcement String       @default("") // 給小隊看的公告（例如「5 分鐘後開始拍賣」）
  status       String       @default("OPEN") // OPEN | ENDED
  lots         AuctionLot[]
  createdAt    DateTime     @default(now()) @db.Timestamptz
  endedAt      DateTime?    @db.Timestamptz
}

// 拍賣品：場次內逐件拍賣（英式喊價、一次一件）。
model AuctionLot {
  id           Int          @id @default(autoincrement())
  eventId      Int // 所屬拍賣場次
  event        AuctionEvent @relation(fields: [eventId], references: [id])
  orderIndex   Int          @default(0) // 場次內拍賣順序
  title        String // 自由文字標題（custom lot 一定有）
  description  String       @default("")
  lotType      String       @default("CUSTOM") // CUSTOM | ITEM | PROPERTY
  assetId      Int? // lotType=ITEM → MovableAsset.id
  propertyId   Int? // lotType=PROPERTY → Property.id
  hiddenValue  Int          @default(0) // ITEM lot 結算秘密幣值（沿用動產規則）
  startPrice   Int          @default(0)
  currentBid   Int          @default(0) // 目前喊到的價（無人出價時 = startPrice）
  status       String       @default("DRAFT") // DRAFT | LIVE | SOLD | PASSED | CANCELLED
  winnerTeamId Int? // 落槌後填
  winnerTeam   Team?        @relation(fields: [winnerTeamId], references: [id])
  finalPrice   Int? // 落槌成交價
  ledgerIds    String       @default("") // CSV：成交時寫入的 ledger ids，供撤銷
  createdAt    DateTime     @default(now()) @db.Timestamptz
  soldAt       DateTime?    @db.Timestamptz

  @@index([eventId, orderIndex])
}

enum ItemEffectType {
  TOLL_INCOME
  TOLL_PAID
  SHOP_PRICE
  MYSTERY_SHOP_PRICE
  PROPERTY_VALUE
  COINS_PER_ROUND
  TAX_COLLECTOR
  GOOD_CARD_BONUS
  BAD_CARD_REDUCE
  WHEEL_BONUS
  WHEEL_NO_ZERO
  WHEEL_STAKE_BOOST
  WHEEL_ON_GOOD_CARD
  LOTTERY_BONUS
  JACKPOT_SHARE
  LOTTERY_INSURANCE
  LOTTERY_FEE_DISCOUNT
  COMPOUND_INTEREST
  PROPERTY_DIVIDEND
  UNDERDOG
  DOUBLE_OR_NOTHING
  ALLIANCE_BONUS
  PIRACY
  MOVEMENT
  REMINDER
  CARD_BLOCK
}

// 動產模板：定義效果種類與強度
model MovableAsset {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  grade        String         // S A B
  effectType   ItemEffectType
  effectValue  Float          @default(0) // +0.15=+15%；負數=負面；COINS_PER_ROUND 單位為光幣
  condition    String?        // JSON：{"region":"AURORA"} 條件觸發；null=無條件
  description  String         @default("")
  defaultUses  Int?           // null=永久；n=預設觸發次數上限
  price        Int            @default(0)  // 神秘商店售價（光幣）；依 grade 給預設，admin 可調
  shopStock    Int            @default(0)  // 神秘商店可購買庫存；0=不在商店上架
  teamItems    TeamItem[]
}

// 動產實例：每隊持有的動產（含秘密幣值）
model TeamItem {
  id            Int          @id @default(autoincrement())
  teamId        Int
  team          Team         @relation(fields: [teamId], references: [id])
  assetId       Int
  asset         MovableAsset @relation(fields: [assetId], references: [id])
  hiddenValue   Int          @default(0)   // 結算時的動產幣值（秘密帳本）
  usesRemaining Int?                       // null=永久；0=已耗盡（active 同步設 false）
  active        Boolean      @default(true) // false = 已失效（耗盡 / 手動撤銷）
  note          String?      // 取得方式備註
  markTeamId    Int?                       // 鎖定目標小隊（海盜旗 PIRACY：被標記隊收過路費時抽成）
  lockedTradeId Int?                       // 非 null = 凍結於某筆 PENDING 交易中（暫不生效、不可重複交易）
  obtainedAt    DateTime     @default(now()) @db.Timestamptz

  @@index([lockedTradeId])
}

model Property {
  id          Int    @id @default(autoincrement())
  name        String @unique
  region      String // AURORA SPECTRA EMBER HAVEN
  type        String // 金融 商業 投資 ... （事件類型加成用）
  basePrice   Int // 採「四區域不動產表」初始價
  level       Int    @default(0) // 0=已購未升級 .. 3
  ownerTeamId       Int? // null = 尚未售出
  owner             Team?  @relation(fields: [ownerTeamId], references: [id])
  cardRegionMult    Float @default(1) // 紅/黑卡・整區永久倍率（每張卡疊乘）
  cardBuildingMult  Float @default(1) // 鬧鬼/土地公卡・單棟永久倍率
  monopolyBonusMult Float @default(1) // HAVEN 獨佔慢慢漲鎖定後的單棟永久漲幅
}

model LotteryNumber {
  id     Int  @id @default(autoincrement())
  period Int // 大樂透期別
  number Int // 1..50
  teamId Int
  team   Team @relation(fields: [teamId], references: [id])

  @@unique([period, number]) // 同期同號不可重複
}

// 全場單例狀態（id 固定為 1）
model GameState {
  id            Int      @id @default(1)
  phase         String   @default("SETUP") // SETUP RUNNING SETTLED
  // 執行期「停用驗證」開關（由 Admin 頁切換）。為 true 時等同 env AUTH_DISABLED：
  // 無 cookie 訪客視為 ADMIN dev session、各 team API 接受 ?teamId= 覆寫（fallback 第一隊）。
  // ⚠️ 開啟＝對外完全不設防，僅供現場測試 / 救援使用。
  authDisabled  Boolean  @default(false)
  activeEvents  String   @default("") // CSV，例如 "1,2"
  event4Penalty String? // 事件四「前次漲最多區域」由主持人選定
  // ── 不動產進階系統可調參數（admin 可調）──
  auroraMultiplier     Float  @default(1.5)   // AURORA 獨佔：光幣收益倍率
  spectraCardPoints    Int    @default(20)    // SPECTRA 獨佔：每回合卡牌點數
  havenApprIntervalMs  Int    @default(60000) // HAVEN 慢慢漲：時間單位（毫秒）
  havenApprRate        Float  @default(0.01)  // HAVEN 慢慢漲：每單位漲幅
  houseIncomeL1        Float  @default(0.03)  // 1 級房每回合營收費率
  houseIncomeL2        Float  @default(0.05)  // 2 級房每回合營收費率
  houseIncomeL3        Float  @default(0.08)  // 3 級房每回合營收費率
  cardRegionUpMult     Float  @default(1.3)   // 紅卡整區漲幅
  cardRegionDownMult   Float  @default(0.75)  // 黑卡整區跌幅
  cardBuildingUpMult   Float  @default(1.3)   // 土地公卡單棟漲幅
  cardBuildingDownMult Float  @default(0.75)  // 鬧鬼卡單棟跌幅
  monopolySince        String @default("")    // CSV region:teamId:epochMs（HAVEN 慢慢漲用）
  lotteryPeriod Int      @default(1)
  lotteryPool   Int      @default(1000)
  // 最近一次大樂透開獎結果（供投影頁重播開獎動畫；null=尚未開過獎）
  lastDrawNumber    Int?
  lastDrawWinnerId  Int? // null = 無人中獎
  lastDrawPool      Int? // 中獎發出 / 無人中獎累積後的金額
  lastDrawAt        DateTime? @db.Timestamptz // 投影頁以此判斷是否有「新的一次開獎」
  settledAt     DateTime?    @db.Timestamptz
  updatedAt     DateTime     @updatedAt @db.Timestamptz
}

// 卡牌商店庫存
model FunctionCard {
  id        Int    @id @default(autoincrement())
  type      String @unique
  effect    String @default("")
  cost      Int    @default(0) // 購買所需卡牌點數（企畫書未定，可於 admin 調整）
  remaining Int
}

// 小隊持有的功能卡（買入未使用的張數）：買入 +1，使用時（各卡效果函式）-1 並回補 FunctionCard.remaining。
model TeamCard {
  id       Int    @id @default(autoincrement())
  teamId   Int
  team     Team   @relation(fields: [teamId], references: [id])
  cardType String
  count    Int    @default(0)

  @@unique([teamId, cardType])
}

// 商店展示的 3 張（slot 0..2）
model ShopDisplay {
  slot     Int     @id
  cardType String?
}

// 流動關主題庫
model Question {
  id         Int     @id @default(autoincrement())
  gameName   String
  prompt     String
  answer     String?
  difficulty String?
  options    String? // 三選一干擾項，以 | 分隔；正解仍存 answer。執行時 [answer, ...options] 洗牌
}

// 稽核總帳：每筆數值變動都記錄，可反向沖銷
model Ledger {
  id        Int      @id @default(autoincrement())
  teamId    Int?
  team      Team?    @relation(fields: [teamId], references: [id])
  kind      String // coins cardPoints property lottery wheel system settlement
  delta     Int      @default(0)
  note      String?
  byToken   String? // 登記站別 label
  reversed  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz
}

// 小隊間交易（單向轉帳；發起即凍結發起方資源，接受才撥給對方）
model Trade {
  id         Int       @id @default(autoincrement())
  fromTeamId Int // 發起方
  toTeamId   Int // 收受方
  coins      Int       @default(0)
  cardPoints Int       @default(0)
  status     String    @default("PENDING") // PENDING ACCEPTED REJECTED CANCELLED
  createdAt  DateTime  @default(now()) @db.Timestamptz
  resolvedAt DateTime? @db.Timestamptz

  @@index([toTeamId, status])
  @@index([fromTeamId, status])
}

// 好運卡「任務型」目標：抽卡當下登記，記下各項基準（since-draw），
// 之後該隊回合結算（地圖階段 2）時自動評估是否達標，達標即發獎並 completedAt。
// 詛咒卡（isCurse=true）共用同一張表：抽卡即發一張詛咒道具（curseItemId）並登記任務目標，
// 達標時除了發 rewardCoins 獎勵，還會把該詛咒道具失效（解除詛咒）。
model TeamObjective {
  id                  Int       @id @default(autoincrement())
  teamId              Int
  team                Team      @relation(fields: [teamId], references: [id])
  cardName            String // 對應 TASK_GOOD_CARDS[] / CURSE_CARDS[].name（顯示用）
  taskKind            String // TaskKind 值
  isCurse             Boolean   @default(false) // true = 詛咒卡（厄運抽到，達標解咒 + 獎勵）
  curseItemId         Int? // isCurse 時，抽卡發放的詛咒 TeamItem id，達標時令其失效
  targetCount         Int       @default(1) // 交易 / 拍賣 次數；其餘用 1
  targetRegion        String? // BUY_LAND 指定區（AURORA/SPECTRA/EMBER/HAVEN）；null = 任一區
  rewardCoins         Int
  // ── 抽卡當下基準（since-draw；各 kind 只用到其中一項，其餘無害）──
  baseTradeCount      Int       @default(0)
  basePropertyCount   Int       @default(0) // 指定區時僅該區
  baseLevel3Count     Int       @default(0)
  baseCardUseCount    Int       @default(0)
  baseAuctionWins     Int       @default(0)
  baseMonopolyRegions String    @default("") // 抽卡時已獨佔的區碼 CSV
  // ── 完成狀態 ──
  completedAt         DateTime? @db.Timestamptz // null = 進行中
  rewardLedgerId      Int? // 發獎 ledger id，供撤銷
  createdAt           DateTime  @default(now()) @db.Timestamptz

  @@index([teamId, completedAt])
}
